# ==============================================
# BANCO DE DADOS
# Use @localhost ao rodar o backend fora do Docker
# ==============================================
DATABASE_URL=postgresql://financeiro:sua_senha_aqui@localhost:5432/financeiro_encontro

# ==============================================
# BACKEND
# ==============================================
UPLOAD_FOLDER=./uploads
APP_PORT=8000

# ==============================================
# BANCO DE DADOS — DEBUG
# ==============================================
# Exibe todas as queries SQL no console (ative somente em desenvolvimento)
SQL_ECHO=false

# ==============================================
# CORS
# ==============================================
# Origens permitidas, separadas por vírgula
CORS_ORIGINS=http://localhost:4200

# ==============================================
# JWT
# ==============================================
# Gere um valor seguro com:
#   python -c "import secrets; print(secrets.token_hex(32))"
JWT_SECRET=sua_chave_secreta_aqui
JWT_ALGORITHM=HS256
JWT_EXPIRE_MINUTES=480
