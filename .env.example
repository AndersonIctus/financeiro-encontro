# ==============================================
# BANCO DE DADOS
# ==============================================
POSTGRES_DB=financeiro_encontro
POSTGRES_USER=financeiro
POSTGRES_PASSWORD=sua_senha_aqui

# Use @postgres para Docker, @localhost para desenvolvimento local
DATABASE_URL=postgresql://financeiro:sua_senha_aqui@postgres:5432/financeiro_encontro

# ==============================================
# BACKEND
# ==============================================
UPLOAD_FOLDER=./uploads
APP_PORT=8000

# ==============================================
# JWT
# ==============================================
# Gere um valor seguro com:
#   python -c "import secrets; print(secrets.token_hex(32))"
JWT_SECRET=sua_chave_secreta_aqui
JWT_ALGORITHM=HS256
JWT_EXPIRE_MINUTES=480
